{% comment %}
  DURNEV — Shared Design Tokens & Base Styles
  Render once in layout or in each section that needs it:
  {% render 'durnev-base-styles' %}
{% endcomment %}

<style>
  :root {
    /* Colors */
    --durnev-bg: #FAFAF8;
    --durnev-bg-warm: #F5F3EF;
    --durnev-text-primary: #18181b;
    --durnev-text-secondary: #71717a;
    --durnev-text-body: #3f3f46;
    --durnev-text-caption: #a1a1aa;
    --durnev-border: rgba(228, 228, 231, 0.5);
    --durnev-accent: #27272a;
    --durnev-dark: #18181b;
    --durnev-white: #FAFAF8;

    /* Typography */
    --durnev-font-display: 'Outfit', sans-serif;
    --durnev-font-body: 'Inter', sans-serif;

    /* Spacing */
    --durnev-container-max: 1400px;
    --durnev-container-pad: clamp(1.5rem, 4vw, 3rem);
    --durnev-section-pad: clamp(4rem, 8vw, 8rem);
    --durnev-grid-gap: clamp(1.5rem, 3vw, 2rem);

    /* Motion */
    --durnev-ease: cubic-bezier(0.16, 1, 0.3, 1);
    --durnev-transition-fast: 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    --durnev-transition-medium: 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    --durnev-transition-slow: 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Shared component styles */
  .durnev-container {
    max-width: var(--durnev-container-max);
    margin: 0 auto;
    padding: 0 var(--durnev-container-pad);
  }

  .durnev-section-label {
    font-family: var(--durnev-font-display);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--durnev-text-secondary);
    margin-bottom: 1rem;
  }

  .durnev-section-title {
    font-family: var(--durnev-font-display);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--durnev-text-primary);
    line-height: 1.2;
  }

  .durnev-btn-primary {
    display: inline-block;
    background: var(--durnev-dark);
    color: var(--durnev-white);
    border-radius: 9999px;
    padding: 1rem 2.5rem;
    font-family: var(--durnev-font-display);
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    transition: all var(--durnev-transition-fast);
    border: 2px solid var(--durnev-dark);
    text-decoration: none;
    cursor: pointer;
  }

  .durnev-btn-primary:hover {
    filter: brightness(1.3);
  }

  .durnev-btn-primary:active {
    transform: translateY(-1px) scale(0.98);
  }

  .durnev-btn-secondary {
    display: inline-block;
    background: transparent;
    color: var(--durnev-dark);
    border: 2px solid var(--durnev-dark);
    border-radius: 9999px;
    padding: 1rem 2.5rem;
    font-family: var(--durnev-font-display);
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    transition: all var(--durnev-transition-fast);
    text-decoration: none;
    cursor: pointer;
  }

  .durnev-btn-secondary:hover {
    background: var(--durnev-dark);
    color: var(--durnev-white);
  }

  .durnev-btn-secondary:active {
    transform: translateY(-1px) scale(0.98);
  }

  .durnev-btn-outline-white {
    display: inline-block;
    background: transparent;
    color: #fff;
    border: 2px solid rgba(255,255,255,0.8);
    border-radius: 9999px;
    padding: 0.875rem 2.25rem;
    font-family: var(--durnev-font-display);
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    transition: all var(--durnev-transition-fast);
    text-decoration: none;
    cursor: pointer;
  }

  .durnev-btn-outline-white:hover {
    background: #fff;
    color: var(--durnev-dark);
  }

  /* Scroll reveal */
  .durnev-reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity var(--durnev-transition-slow), transform var(--durnev-transition-slow);
  }

  .durnev-reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .durnev-stagger-child {
    opacity: 0;
    transform: translateY(15px);
    transition: opacity var(--durnev-transition-medium), transform var(--durnev-transition-medium);
  }

  .durnev-stagger-child.visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .durnev-reveal,
    .durnev-stagger-child {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  /* Scroll reveal — IntersectionObserver (runs once) */
  if (!window.__durnevRevealInit) {
    window.__durnevRevealInit = true;

    function initDurnevReveal() {
      var els = document.querySelectorAll('.durnev-reveal');
      var staggerParents = document.querySelectorAll('[data-durnev-stagger]');

      var revealObs = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            revealObs.unobserve(entry.target);
          }
        });
      }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });

      els.forEach(function(el) { revealObs.observe(el); });

      var staggerObs = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            var children = entry.target.querySelectorAll('.durnev-stagger-child');
            children.forEach(function(child, i) {
              child.style.transitionDelay = (i * 100) + 'ms';
              requestAnimationFrame(function() { child.classList.add('visible'); });
            });
            staggerObs.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -20px 0px' });

      staggerParents.forEach(function(el) { staggerObs.observe(el); });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initDurnevReveal);
    } else {
      initDurnevReveal();
    }
  }
</script>
