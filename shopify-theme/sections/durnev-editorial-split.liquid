{% render 'durnev-base-styles' %}

<section
  id="durnev-editorial-{{ section.id }}"
  class="durnev-editorial"
  aria-label="Про бренд DURNEV"
>
  <div class="durnev-container">
    <div class="durnev-editorial__grid">
      <div class="durnev-editorial__content durnev-reveal">
        {% if section.settings.label != blank %}
          <span class="durnev-section-label">{{ section.settings.label | escape }}</span>
        {% endif %}

        <h2 class="durnev-editorial__title">{{ section.settings.heading | escape }}</h2>

        {% if section.settings.text != blank %}
          <p class="durnev-editorial__text">{{ section.settings.text | escape }}</p>
        {% endif %}

        {% if section.settings.cta_label != blank %}
          <div class="durnev-editorial__cta">
            <a href="{{ section.settings.cta_link }}" class="durnev-btn-secondary">
              {{ section.settings.cta_label | escape }}
            </a>
          </div>
        {% endif %}
      </div>

      <div class="durnev-editorial__image-wrap durnev-reveal">
        {% if section.settings.image != blank %}
          {{ section.settings.image | image_url: width: 1000 | image_tag:
            loading: 'lazy',
            class: 'durnev-editorial__image',
            widths: '500,700,1000',
            sizes: '(min-width: 768px) 50vw, 100vw'
          }}
        {% else %}
          <img
            src="https://picsum.photos/seed/durnev-about/800/1000"
            alt="Про бренд DURNEV"
            class="durnev-editorial__image"
            loading="lazy"
            width="800"
            height="1000"
          >
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .durnev-editorial {
    padding: var(--durnev-section-pad) 0;
    background: var(--durnev-bg);
  }

  .durnev-editorial__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 4vw, 3rem);
    align-items: center;
  }

  .durnev-editorial__image-wrap {
    overflow: hidden;
    border-radius: 0.5rem;
    order: -1;
  }

  .durnev-editorial__image {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    display: block;
  }

  .durnev-editorial__content {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .durnev-editorial__title {
    font-family: var(--durnev-font-display);
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--durnev-text-primary);
    line-height: 1.1;
    margin: 0;
  }

  .durnev-editorial__text {
    font-family: var(--durnev-font-body);
    font-size: 1.0625rem;
    color: var(--durnev-text-body);
    max-width: 50ch;
    line-height: 1.8;
    margin: 0;
  }

  .durnev-editorial__cta {
    margin-top: 0.5rem;
  }

  @media (min-width: 768px) {
    .durnev-editorial__grid {
      grid-template-columns: 1fr 1fr;
    }

    .durnev-editorial__image-wrap {
      order: 0;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Editorial Split",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "Про Бренд"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Одяг для тих, хто не мовчить"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Body text",
      "default": "DURNEV — це більше, ніж мерч. Це спільнота людей, які цінують чесність, свободу та український характер. Кожна річ створена з увагою до деталей та повагою до тих, хто її носить."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Дізнатись Більше"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Editorial Split"
    }
  ]
}
{% endschema %}
