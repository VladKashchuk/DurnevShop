{% render 'durnev-base-styles' %}

<section
  id="durnev-categories-{{ section.id }}"
  class="durnev-categories durnev-reveal"
  aria-label="Категорії товарів"
>
  <div class="durnev-container">
    <h2 class="durnev-section-title durnev-categories__title">
      {{ section.settings.heading | escape }}
    </h2>

    <div class="durnev-categories__grid" data-durnev-stagger>
      {% for block in section.blocks %}
        <article
          class="durnev-category-card {% if forloop.first %}durnev-category-card--large{% else %}durnev-category-card--small{% endif %} durnev-stagger-child"
          {{ block.shopify_attributes }}
        >
          {% if block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 1000 | image_tag:
              loading: 'lazy',
              class: 'durnev-category-card__image',
              widths: '400,600,800,1000',
              sizes: '(min-width: 768px) 50vw, 100vw'
            }}
          {% else %}
            <img
              src="https://picsum.photos/seed/durnev-cat{{ forloop.index }}/800/1000"
              alt="{{ block.settings.name | escape }}"
              class="durnev-category-card__image"
              loading="lazy"
              width="800"
              height="1000"
            >
          {% endif %}
          <div class="durnev-category-card__overlay">
            <span class="durnev-category-card__name">{{ block.settings.name | escape }}</span>
            {% if block.settings.link != blank %}
              <a href="{{ block.settings.link }}" class="durnev-btn-outline-white durnev-btn--small">
                Shop Now
              </a>
            {% endif %}
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .durnev-categories {
    padding: var(--durnev-section-pad) 0;
    background: var(--durnev-bg);
  }

  .durnev-categories__title {
    text-align: center;
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }

  .durnev-categories__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .durnev-category-card {
    position: relative;
    overflow: hidden;
    border-radius: 0.5rem;
  }

  .durnev-category-card--large {
    aspect-ratio: 4 / 5;
  }

  .durnev-category-card--small {
    aspect-ratio: 6 / 5;
  }

  .durnev-category-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .durnev-category-card:hover .durnev-category-card__image {
    transform: scale(1.03);
  }

  .durnev-category-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.5) 0%, rgba(0,0,0,0.1) 40%, transparent 100%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: clamp(1.5rem, 3vw, 2.5rem);
    gap: 0.75rem;
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .durnev-category-card:hover .durnev-category-card__overlay {
    background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0.15) 50%, transparent 100%);
  }

  .durnev-category-card__name {
    transform: translateY(4px);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .durnev-category-card:hover .durnev-category-card__name {
    transform: translateY(0);
  }

  .durnev-category-card .durnev-btn--small {
    opacity: 0;
    transform: translateY(8px);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .durnev-category-card:hover .durnev-btn--small {
    opacity: 1;
    transform: translateY(0);
  }

  .durnev-category-card__name {
    font-family: var(--durnev-font-display);
    font-size: clamp(1.125rem, 2vw, 1.5rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #fff;
  }

  .durnev-btn--small {
    align-self: flex-start;
    padding: 0.65rem 1.5rem;
    font-size: 0.7rem;
  }

  /* Tablet+: asymmetric 2fr 1fr grid */
  @media (min-width: 768px) {
    .durnev-categories__grid {
      grid-template-columns: 2fr 1fr;
      grid-template-rows: 1fr 1fr;
    }

    .durnev-category-card--large {
      grid-row: 1 / 3;
      aspect-ratio: auto;
    }

    .durnev-category-card--small {
      aspect-ratio: auto;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Categories Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by Category"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Category name",
          "default": "Category"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Category link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Categories Grid",
      "blocks": [
        { "type": "category", "settings": { "name": "Худі та Світшоти" } },
        { "type": "category", "settings": { "name": "Футболки" } },
        { "type": "category", "settings": { "name": "Аксесуари" } }
      ]
    }
  ]
}
{% endschema %}
