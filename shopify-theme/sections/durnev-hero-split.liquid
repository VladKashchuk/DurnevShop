{% render 'durnev-base-styles' %}

<section
  id="durnev-hero-{{ section.id }}"
  class="durnev-hero-split"
  aria-label="Головний банер"
>
  <div class="durnev-hero-split__content">
    {% if section.settings.overline != blank %}
      <span class="durnev-hero-split__overline durnev-hero-anim">
        {{ section.settings.overline | escape }}
      </span>
    {% endif %}

    <h1 class="durnev-hero-split__title durnev-hero-anim">
      {{ section.settings.heading | escape }}
    </h1>

    {% if section.settings.subheading != blank %}
      <p class="durnev-hero-split__subtitle durnev-hero-anim">
        {{ section.settings.subheading | escape }}
      </p>
    {% endif %}

    {% if section.settings.cta_label != blank %}
      <div class="durnev-hero-split__cta durnev-hero-anim">
        <a href="{{ section.settings.cta_link }}" class="durnev-btn-primary">
          {{ section.settings.cta_label | escape }}
        </a>
      </div>
    {% endif %}
  </div>

  <div class="durnev-hero-split__image-wrap">
    {% if section.settings.image != blank %}
      {{ section.settings.image | image_url: width: 1200 | image_tag:
        loading: 'eager',
        class: 'durnev-hero-split__image',
        widths: '600,900,1200',
        sizes: '(min-width: 1024px) 50vw, 100vw'
      }}
    {% else %}
      <img
        src="https://picsum.photos/seed/durnev-hero/900/1200"
        alt="Hero placeholder"
        class="durnev-hero-split__image"
        loading="eager"
        width="900"
        height="1200"
      >
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .durnev-hero-split {
    display: grid;
    grid-template-columns: 1fr;
    min-height: auto;
    background: var(--durnev-bg);
  }

  .durnev-hero-split__image-wrap {
    order: -1;
    position: relative;
    overflow: hidden;
    opacity: 0;
    animation: durnevHeroFade 1s cubic-bezier(0.16, 1, 0.3, 1) 0.3s forwards;
  }

  .durnev-hero-split__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 3 / 4;
  }

  .durnev-hero-split__content {
    padding: clamp(2.5rem, 6vw, 4rem) clamp(1.5rem, 4vw, 3rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1.5rem;
  }

  .durnev-hero-split__overline {
    font-family: var(--durnev-font-display);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--durnev-text-secondary);
  }

  .durnev-hero-split__title {
    font-family: var(--durnev-font-display);
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--durnev-text-primary);
    line-height: 1.05;
    margin: 0;
  }

  .durnev-hero-split__subtitle {
    font-family: var(--durnev-font-body);
    font-size: 1.0625rem;
    color: var(--durnev-text-body);
    max-width: 40ch;
    line-height: 1.7;
    margin: 0;
  }

  .durnev-hero-split__cta {
    margin-top: 0.5rem;
  }

  /* Load animation */
  .durnev-hero-anim {
    opacity: 0;
    transform: translateY(20px);
    animation: durnevHeroFade 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .durnev-hero-anim:nth-child(1) { animation-delay: 0.1s; }
  .durnev-hero-anim:nth-child(2) { animation-delay: 0.2s; }
  .durnev-hero-anim:nth-child(3) { animation-delay: 0.3s; }
  .durnev-hero-anim:nth-child(4) { animation-delay: 0.4s; }

  @keyframes durnevHeroFade {
    to { opacity: 1; transform: translateY(0); }
  }

  /* Desktop: split layout */
  @media (min-width: 1024px) {
    .durnev-hero-split {
      grid-template-columns: 1fr 1fr;
      min-height: 85dvh;
    }

    .durnev-hero-split__image-wrap {
      order: 0;
    }

    .durnev-hero-split__image {
      aspect-ratio: auto;
      min-height: 85dvh;
    }

    .durnev-hero-split__content {
      padding: clamp(3rem, 6vw, 6rem);
    }
  }

  @media (min-width: 1280px) {
    .durnev-hero-split__title {
      font-size: 3.75rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .durnev-hero-anim,
    .durnev-hero-split__image-wrap {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero Split Screen",
  "settings": [
    {
      "type": "text",
      "id": "overline",
      "label": "Overline text",
      "default": "Весна 2026"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Нова Колекція"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Стиль, який не потребує пояснень. Лімітована лінійка мерчу, створена в Україні."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Hero Split Screen"
    }
  ]
}
{% endschema %}
