{% render 'durnev-base-styles' %}

<section
  id="durnev-featured-{{ section.id }}"
  class="durnev-featured durnev-reveal"
  aria-label="Бестселери"
>
  <div class="durnev-container">
    <div class="durnev-featured__header">
      <h2 class="durnev-section-title">{{ section.settings.heading | escape }}</h2>
      {% if section.settings.link_label != blank %}
        <a href="{{ section.settings.link_url }}" class="durnev-featured__link">
          {{ section.settings.link_label | escape }}
        </a>
      {% endif %}
    </div>

    <div class="durnev-featured__track" data-durnev-stagger>
      {% if section.settings.collection != blank %}
        {% for product in collections[section.settings.collection].products limit: section.settings.products_count %}
          <article class="durnev-product-card durnev-stagger-child">
            <a href="{{ product.url }}" aria-label="{{ product.title }}, {{ product.price | money }}">
              <div class="durnev-product-card__image-wrap">
                {% if product.featured_image %}
                  {{ product.featured_image | image_url: width: 700 | image_tag:
                    loading: 'lazy',
                    class: 'durnev-product-card__image',
                    widths: '350,500,700',
                    sizes: '(min-width: 1024px) 25vw, 70vw'
                  }}
                {% endif %}
              </div>
              <div class="durnev-product-card__info">
                <p class="durnev-product-card__name">{{ product.title | escape }}</p>
                <p class="durnev-product-card__price">{{ product.price | money }}</p>
              </div>
            </a>
          </article>
        {% endfor %}
      {% else %}
        {%- comment -%} Placeholder products when no collection selected {%- endcomment -%}
        {% assign placeholder_names = "Худі Oversized,Світшот Classic,Футболка Basic,Шкарпетки Pack,Кепка Logo,Лонгслів Signature,Штани Cargo,Шопер Logo" | split: "," %}
        {% assign placeholder_prices = "1 800,1 500,900,450,750,1 200,2 200,600" | split: "," %}
        {% for name in placeholder_names %}
          <article class="durnev-product-card durnev-stagger-child">
            <a href="#" aria-label="{{ name }}, {{ placeholder_prices[forloop.index0] }} грн">
              <div class="durnev-product-card__image-wrap">
                <img
                  src="https://picsum.photos/seed/durnev-product-{{ forloop.index }}/700/930"
                  alt="{{ name }}"
                  class="durnev-product-card__image"
                  loading="lazy"
                  width="700"
                  height="930"
                >
              </div>
              <div class="durnev-product-card__info">
                <p class="durnev-product-card__name">{{ name }}</p>
                <p class="durnev-product-card__price">{{ placeholder_prices[forloop.index0] }} &#8372;</p>
              </div>
            </a>
          </article>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{% stylesheet %}
  .durnev-featured {
    padding: var(--durnev-section-pad) 0;
    background: var(--durnev-bg);
  }

  .durnev-featured__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 2.5rem;
  }

  .durnev-featured__link {
    font-family: var(--durnev-font-display);
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--durnev-text-secondary);
    transition: color var(--durnev-transition-fast);
    border-bottom: 1px solid transparent;
    text-decoration: none;
  }

  .durnev-featured__link:hover {
    color: var(--durnev-text-primary);
    border-bottom-color: var(--durnev-text-primary);
  }

  .durnev-featured__track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    gap: var(--durnev-grid-gap);
    padding-bottom: 1.5rem;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: #d4d4d8 transparent;
  }

  .durnev-featured__track::-webkit-scrollbar { height: 4px; }
  .durnev-featured__track::-webkit-scrollbar-track { background: transparent; }
  .durnev-featured__track::-webkit-scrollbar-thumb { background: #d4d4d8; border-radius: 4px; }

  .durnev-product-card {
    scroll-snap-align: start;
    flex-shrink: 0;
    width: clamp(260px, 25vw, 340px);
  }

  .durnev-product-card a {
    text-decoration: none;
    color: inherit;
  }

  .durnev-product-card__image-wrap {
    position: relative;
    overflow: hidden;
    border-radius: 0.5rem;
    aspect-ratio: 3 / 4;
    background: #e8e8e4;
  }

  /* Skeleton shimmer */
  .durnev-product-card__image-wrap::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, #e8e8e4 0%, #f0eeea 40%, #e8e8e4 80%);
    background-size: 200% 100%;
    animation: durnevShimmer 1.8s ease-in-out infinite;
    z-index: 1;
    transition: opacity 0.4s ease;
  }

  .durnev-product-card__image-wrap.loaded::before {
    opacity: 0;
    pointer-events: none;
  }

  @keyframes durnevShimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  .durnev-product-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    z-index: 2;
  }

  /* Quick-view overlay */
  .durnev-product-card__image-wrap::after {
    content: 'QUICK VIEW';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1rem;
    background: rgba(24, 24, 27, 0.85);
    color: var(--durnev-white);
    font-family: var(--durnev-font-display);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    text-align: center;
    z-index: 3;
    transform: translateY(100%);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .durnev-product-card:hover .durnev-product-card__image {
    transform: scale(1.05);
  }

  .durnev-product-card:hover .durnev-product-card__image-wrap::after {
    transform: translateY(0);
  }

  .durnev-product-card__info {
    padding-top: 1rem;
  }

  .durnev-product-card__name {
    font-family: var(--durnev-font-display);
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--durnev-text-primary);
    margin: 0 0 0.25rem;
  }

  .durnev-product-card__price {
    font-family: var(--durnev-font-body);
    font-size: 0.875rem;
    color: var(--durnev-text-secondary);
    margin: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Featured Carousel",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Бестселери"
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Link label",
      "default": "Shop All"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_count",
      "label": "Products to show",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Featured Carousel"
    }
  ]
}
{% endschema %}
